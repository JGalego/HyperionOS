# Base: Buildroot's own proven qemu_aarch64_virt reference config (board/qemu/aarch64-virt/linux.config
# in the vendored Buildroot copy) -- chosen over Buildroot's Raspberry Pi board support
# (board/raspberrypi4-64/ etc.) because it already boots correctly on plain `qemu-system-aarch64
# -M virt`, the sandbox-achievable verification this board targets, using a generic virtio/PL011
# machine model instead of Pi-specific GPU firmware blobs and a vendor kernel fork. See this repo's
# PRODUCTION_BOOT_PROMPT.md M11 completion note for why real Raspberry Pi hardware itself is a
# separate, deferred, real-hardware-only step this config does not attempt to satisfy on its own.
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y
CONFIG_NO_HZ_IDLE=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_TASKSTATS=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_CPUSETS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_SCHED_AUTOGROUP=y
CONFIG_PROFILING=y
CONFIG_ARCH_VEXPRESS=y
CONFIG_COMPAT=y
CONFIG_ACPI=y
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_BLK_DEV_BSGLIB=y
CONFIG_BINFMT_MISC=y
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_PACKET_DIAG=y
CONFIG_UNIX=y
CONFIG_NET_KEY=y
CONFIG_INET=y
CONFIG_IP_MULTICAST=y
CONFIG_IP_ADVANCED_ROUTER=y
CONFIG_BRIDGE=m
CONFIG_NET_SCHED=y
CONFIG_VSOCKETS=y
CONFIG_PCI=y
CONFIG_PCI_HOST_GENERIC=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_FW_CFG_SYSFS=y
CONFIG_FW_CFG_SYSFS_CMDLINE=y
CONFIG_VIRTIO_BLK=y
CONFIG_BLK_DEV_SD=y
CONFIG_CHR_DEV_SG=y
CONFIG_SCSI_CONSTANTS=y
CONFIG_SCSI_LOGGING=y
CONFIG_SCSI_SCAN_ASYNC=y
CONFIG_SCSI_VIRTIO=y
CONFIG_ATA=y
CONFIG_NETDEVICES=y
CONFIG_DUMMY=y
CONFIG_MACVLAN=y
CONFIG_VIRTIO_NET=y
CONFIG_NLMON=y
CONFIG_INPUT_EVDEV=y
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_TCG_TPM=y
CONFIG_TCG_TIS=y
CONFIG_DRM=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_FB=y
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_PL031=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_INPUT=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES=y
CONFIG_MAILBOX=y
CONFIG_PL320_MBOX=y
CONFIG_ARM_SMMU_V3=y
CONFIG_EXT4_FS=y
CONFIG_FUSE_FS=y
CONFIG_VIRTIO_FS=y
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y

# --- Hyperion M0: real enforcement primitives M2/M4 build on (PRODUCTION_BOOT_PROMPT.md) ---
# Verbatim from board/hyperion-x86_64/linux.config: every symbol here is a generic,
# architecture-independent Kconfig option (confirmed against this kernel's own Kconfig sources
# before reuse), so the identical block enforces the identical guarantee on both reference
# platforms. A few (MEMCG, BLK_CGROUP, CPUSETS) duplicate a symbol the aarch64-virt base above
# already sets -- harmless, Kconfig fragment merging is idempotent on an identical value.
#
# Namespaces: every Trust Depth in docs/03's sandboxing spectrum (process through
# container) is implemented as some subset of these.
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_TIME_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
# Note: cgroup namespacing has no separate Kconfig gate in this kernel series --
# it's unconditionally available whenever CONFIG_CGROUPS=y below is set.

# cgroups v2 (unified hierarchy) + the controllers M4's scheduler maps
# ResourceVector/ResourceLedger onto instead of replacing.
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_BPF=y
CONFIG_CGROUP_PERF=y
CONFIG_CPUSETS=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_BLK_DEV_THROTTLING=y
CONFIG_PSI=y

# seccomp-bpf: the syscall-scoping half of M2's Capability Monitor enforcement.
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# Landlock LSM: the filesystem-scoping half of M2's Capability Monitor enforcement.
CONFIG_SECURITY=y
CONFIG_SECURITY_LANDLOCK=y
